# Copy to .env and fill in actual values

# Supabase Postgres — get from Project Settings → Database → Connection string
# Transaction pooler (used by the app at runtime, port 6543, with pgbouncer=true)
DATABASE_URL="postgres://postgres.<ref>:<PASSWORD>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection (used by Prisma migrations + seeding, port 5432)
DIRECT_URL="postgres://postgres.<ref>:<PASSWORD>@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# Long random string. Generate with: openssl rand -base64 48
SESSION_SECRET="change-me-to-a-long-random-string"

# Initial admin password — applied on first seed. The owner can change it later.
DEFAULT_PASSWORD="Admin@123"

# Set to "true" only when deploying behind HTTPS (Vercel, Cloudflare, etc.).
# Leave off (or set to "false") for localhost development.
COOKIE_SECURE="false"
